---
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const asset = (path) => `${base.replace(/\/?$/, "/")}${path}`;

const ecosystem = [
  {
    name: "Grupo de Control y Procesamiento Digital de Señales",
    detail: "Fundación 1998 - A1 Minciencias",
    image: "logos/logogcpds.png",
    href: "https://scienti.minciencias.gov.co/gruplac/jsp/visualiza/visualizagr.jsp?nro=00000000001375"
  },
  {
    name: "Semillero de Investigación en Ciencia de Datos e Inteligencia Artificial",
    detail: "Formación aplicada en ciencia de datos, aprendizaje automático e IA",
    image: "logos/logoDatosIA.png"
  },
  {
    name: "Semillero de Investigación en Física e Inteligencia Artificial",
    detail: "Modelado, simulación y física computacional soportada por IA",
    image: "logos/logoFisicaIA.png"
  }
];

const purposes = [
  "I+D+i desde IA, ofreciendo experiencias formativas que integran teoría y práctica",
  "Impulsar el desarrollo de sistemas inteligentes soportados por IA mediante la generación de soluciones innovadoras con impacto regional y nacional",
  "Crear productos y servicios tecnológicos basados en IA",
  "Vincular estudiantes de pregrado y posgrado en proyectos interdisciplinarios"
];

const programs = [
  "Ingeniería Eléctrica",
  "Ingeniería Electrónica",
  "Ingeniería Física",
  "Ciencias de la Computación",
  "Matemáticas",
  "Estadística",
  "Especialización en Aprendizaje Automático e IA",
  "Maestría en Automatización Industrial",
  "Maestría en Ciencias - Física",
  "Doctorado en Ingeniería - Automática"
];

const lines = [
  { title: "Visión por computador", image: "lineas/visionpc-web.png" },
  { title: "Neuroingeniería", image: "lineas/neuroingenieria-web.png" },
  { title: "Analítica de datos", image: "lineas/analitica-web.png" },
  { title: "Agricultura inteligente", image: "lineas/agriculturainteligente-web.png" },
  { title: "Energías renovables", image: "lineas/energiasrenovables-web.png" },
  { title: "LLMs y agentes", image: "lineas/agentes-web.png" },
  { title: "Física computacional", image: "lineas/fisicacomputacional-web.png" },
  { title: "Computación cuántica", image: "lineas/cuantica-web.png" },
  { title: "Desarrollo de software + IA", image: "lineas/desarrollosoftware-web.png" }
];

const allies = [
  { name: "Acemate", file: "transparentes/acemate.png" },
  { name: "Aguas de Manizales", file: "transparentes/aguasMzls.png" },
  { name: "BIOS", file: "transparentes/bios.png" },
  { name: "Universidad de Kentucky", file: "transparentes/uk.png" },
  { name: "CHEC", file: "transparentes/chec.png" },
  { name: "Casa Luker", file: "transparentes/luker.png" },
  { name: "Minciencias", file: "transparentes/minciencias.png" },
  { name: "Multilab", file: "transparentes/multilab.png" },
  { name: "Neurocentro", file: "transparentes/neurocentro.png" },
  { name: "SES", file: "transparentes/ses.png" },
  { name: "Universidad Autónoma de Manizales", file: "transparentes/uam.png" },
  { name: "Universidad de Caldas", file: "transparentes/ucaldas.png" },
  { name: "Universidad de Antioquia", file: "transparentes/udea.png" },
  { name: "Universidad Nacional de Colombia", file: "transparentes/unal.png" },
  { name: "UTEC", file: "transparentes/utec.png" },
  { name: "ANE", file: "transparentes/ane.png" },
  { name: "Universidad de Edimburgo", file: "transparentes/uedimburgo.png" },
  { name: "Universidad de Valencia", file: "transparentes/uvalencia.png" },
  { name: "Agrosavia", file: "transparentes/agrosavia.png" },
  { name: "University of Florida", file: "transparentes/uf.png" },
  { name: "Datapeers", file: "transparentes/datapeers.png" },
  { name: "ITBA", file: "transparentes/itba.png" },
  { name: "UPSE", file: "transparentes/upse.png" },
  { name: "UTP", file: "transparentes/utp.png" }
];

const relatedLinks = [
  {
    title: "GrupLAC Minciencias",
    links: [
      {
        label: "Grupo de Control y Procesamiento Digital de Señales",
        href: "https://scienti.minciencias.gov.co/gruplac/jsp/visualiza/visualizagr.jsp?nro=00000000001375"
      }
    ]
  },
  {
    title: "Prof. Germán Castellanos",
    links: [
      {
        label: "CvLAC - Investigador Senior",
        href: "https://scienti.minciencias.gov.co/cvlac/visualizador/generarCurriculoCv.do?cod_rh=0000043222"
      },
      {
        label: "Google Scholar",
        href: "https://scholar.google.com/citations?user=RbCdiT0AAAAJ&hl=es&oi=ao"
      }
    ]
  },
  {
    title: "Prof. Andrés Marino Álvarez",
    links: [
      {
        label: "CvLAC - Investigador Senior",
        href: "https://scienti.minciencias.gov.co/cvlac/visualizador/generarCurriculoCv.do?cod_rh=0001330950"
      },
      {
        label: "Google Scholar",
        href: "https://scholar.google.com/citations?user=4aUwQtAAAAAJ&hl=en"
      }
    ]
  }
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Laboratorio de Inteligencia Artificial de la Universidad Nacional de Colombia, sede Manizales"
    />
    <title>Laboratorio de Inteligencia Artificial | UNAL Manizales</title>
    <link rel="icon" type="image/png" href={asset("logos/logo_labIA.png")} />
  </head>
  <body>
    <header class="site-header" aria-label="Navegación principal">
      <a class="brand" href="#inicio" aria-label="Ir al inicio">
        <img src={asset("logos/logo_labIA.png")} alt="" />
        <span>LIA-UNAL</span>
      </a>
      <nav>
        <a href="#inicio">Inicio</a>
        <a href="#ecosistema">Ecosistema</a>
        <a href="#propositos">Propósitos</a>
        <a href="#programas">Programas</a>
        <a href="#lineas">Líneas</a>
        <a href="#aliados">Aliados</a>
        <a href="#enlaces">Enlaces</a>
        <a href="#contacto">Contacto</a>
      </nav>
    </header>

    <main id="inicio">
      <section class="hero section">
        <div class="ai-field" aria-hidden="true">
          <span class="node n1"></span>
          <span class="node n2"></span>
          <span class="node n3"></span>
          <span class="node n4"></span>
          <span class="node n5"></span>
          <span class="node n6"></span>
          <span class="pulse p1"></span>
          <span class="pulse p2"></span>
          <span class="pulse p3"></span>
          <svg viewBox="0 0 900 540" role="presentation" focusable="false">
            <path d="M98 128 C230 64 310 210 438 146 S690 104 788 232" />
            <path d="M110 390 C260 270 370 428 500 302 S692 262 808 404" />
            <path d="M202 120 L340 298 L520 170 L700 332" />
            <path d="M150 360 L322 180 L552 368 L748 150" />
          </svg>
        </div>
        <div class="hero-content">
          <img class="hero-logo" src={asset("logos/logo_labIA.png")} alt="Logo del Laboratorio de Inteligencia Artificial" />
          <h1 class="sr-only">Laboratorio de Inteligencia Artificial</h1>
          <p class="lead">
            I+D+i, formación avanza y soluciones tecnológicas basadas en IA
          </p>
          <p class="hero-university">Universidad Nacional de Colombia - Sede Manizales</p>
        </div>
      </section>

      <section id="ecosistema" class="section">
        <div class="section-heading">
          <p class="eyebrow">Ecosistema</p>
          <h2>Grupo de investigación, semilleros y talento humano</h2>
        </div>

        <div class="ecosystem-grid">
          {
            ecosystem.map((item) => {
              const CardTag = item.href ? "a" : "article";
              return (
                <CardTag
                  class="ecosystem-card"
                  href={item.href}
                  target={item.href ? "_blank" : undefined}
                  rel={item.href ? "noreferrer" : undefined}
                >
                  <img src={asset(item.image)} alt={`Logo ${item.name}`} loading="lazy" />
                  <div>
                    <h3>{item.name}</h3>
                    <p>{item.detail}</p>
                  </div>
                </CardTag>
              );
            })
          }
        </div>

        <div class="talent">
          <img src={asset("logos/miembros_lab.jpeg")} alt="Miembros del ecosistema del laboratorio" loading="lazy" />
          <div class="talent-copy">
            <p class="eyebrow">Talento humano</p>
            <h3>Comunidad académica conectada con IA aplicada</h3>
            <ul class="professor-list" aria-label="Profesores del laboratorio">
              <li>Germán Castellanos-Domínguez, Ph.D. (Dir. GCPDS)</li>
              <li>Jorge Iván Montes-Monsalve, Ph.D. (Líder Física+IA)</li>
              <li>Andrés Marino Álvarez-Meza, Ph.D. (Dir. LIA-UNAL)</li>
            </ul>
            <div class="metrics" aria-label="Métricas de talento humano">
              <span><strong>+40</strong> doctores formados</span>
              <span><strong>+80</strong> magísteres formados</span>
              <span><strong>+300</strong> estudiantes de pregrado vinculados</span>
            </div>
          </div>
        </div>
      </section>

      <section id="propositos" class="section split">
        <div>
          <p class="eyebrow">Propósitos</p>
          <h2>IA para aprender, crear y transferir tecnología</h2>
        </div>
        <div class="purpose-list">
          {purposes.map((purpose) => <article><span></span><p>{purpose}</p></article>)}
        </div>
      </section>

      <section id="programas" class="section programs">
        <div class="section-heading">
          <p class="eyebrow">Impacto académico</p>
          <h2>Programas académicos impactados</h2>
        </div>
        <div class="program-grid">
          {programs.map((program) => <span>{program}</span>)}
        </div>
      </section>

      <section id="lineas" class="section work-lines">
        <div class="section-heading">
          <p class="eyebrow">Líneas de trabajo</p>
          <h2>I+D+i desde IA</h2>
        </div>
        <div class="line-grid">
          {
            lines.map((line) => (
              <article class="line-card">
                <div class="line-visual" aria-hidden="true">
                  <img src={asset(line.image)} alt="" loading="lazy" />
                </div>
                <h3>{line.title}</h3>
              </article>
            ))
          }
        </div>
      </section>

      <section id="aliados" class="section allies">
        <div class="section-heading">
          <p class="eyebrow">Aliados</p>
          <h2>Red de trabajo</h2>
        </div>
        <div class="ally-carousel" aria-label="Logos de aliados">
          <div class="ally-track">
            <div class="ally-set">
              {allies.map((ally) => <img src={asset(`aliados/${ally.file}`)} alt={ally.name} />)}
            </div>
            <div class="ally-set" aria-hidden="true">
              {allies.map((ally) => <img src={asset(`aliados/${ally.file}`)} alt="" />)}
            </div>
          </div>
        </div>
      </section>

      <section id="enlaces" class="section related-links">
        <div class="section-heading">
          <p class="eyebrow">Enlaces relacionados</p>
          <h2>Links de interés</h2>
        </div>
        <div class="related-grid">
          {
            relatedLinks.map((group) => (
              <article class="related-card">
                <h3>{group.title}</h3>
                <div class="related-actions">
                  {
                    group.links.map((link) => (
                      <a href={link.href} target="_blank" rel="noreferrer">
                        {link.label}
                      </a>
                    ))
                  }
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section id="contacto" class="section location contact">
        <div class="section-copy">
          <p class="eyebrow">Contacto</p>
          <a class="contact-mail" href="mailto:amalvarezme@unal.edu.co">amalvarezme@unal.edu.co</a>
          <p>
            km 7 vía al Magdalena, Campus La Nubia, Bloque S1-114,
            Laboratorio de Inteligencia Artificial, Universidad Nacional de Colombia,
            sede Manizales-Caldas, Colombia
          </p>
          <img class="location-logo" src={asset("logos/logo_unal_transparente.png")} alt="Logo Universidad Nacional de Colombia" />
        </div>
        <figure class="image-panel">
          <img src={asset("logos/lanubia.jpg")} alt="Campus La Nubia de la Universidad Nacional de Colombia" />
        </figure>
      </section>
    </main>
  </body>
</html>
