---
import "../styles/global.css";

const base = import.meta.env.BASE_URL;
const asset = (path) => `${base.replace(/\/?$/, "/")}${path}`;

const strategies = [
  {
    step: "01",
    title: "Vibe coding",
    text: "Exploración rápida basada en intuición, flujo creativo y baja fricción documental para idear y prototipar"
  },
  {
    step: "02",
    title: "Vibe engineering",
    text: "Estructura ligera sobre la intuición para mejorar la experiencia del desarrollador y acelerar refinamientos"
  },
  {
    step: "03",
    title: "Desarrollo por prompts",
    text: "Traduce necesidades y criterios al lenguaje natural para generar, iterar y validar implementaciones con IA"
  }
];

const tags = [
  "Contratos formales",
  "Agentes de seguridad",
  "Sandboxes aislados",
  "Arquitectura trazable"
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Desarrollo de software mediado por inteligencia artificial en el Laboratorio de Inteligencia Artificial UNAL"
    />
    <title>Desarrollo de software + IA | LIA-UNAL</title>
    <link rel="icon" type="image/png" href={asset("logos/logo_labIA.png")} />
  </head>
  <body>
    <header class="site-header" aria-label="Navegación principal">
      <a class="brand" href={asset("")} aria-label="Volver al inicio">
        <img src={asset("logos/logo_labIA.png")} alt="" />
        <span>LIA-UNAL</span>
      </a>
      <details class="nav-menu">
        <summary aria-label="Abrir menú de navegación">
          <span class="menu-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </summary>
        <nav class="nav-panel" aria-label="Secciones principales">
          <a href={asset("")}>Inicio</a>
          <a href={asset("#ecosistema")}>Ecosistema</a>
          <a href={asset("#propositos")}>Propósitos</a>
          <a href={asset("#programas")}>Programas</a>
          <a href={asset("#lineas")}>Líneas</a>
          <a href={asset("#aliados")}>Aliados</a>
          <a href={asset("#enlaces")}>Enlaces</a>
          <a href={asset("#contacto")}>Contacto</a>
        </nav>
      </details>
    </header>

    <main>
      <section class="section detail-hero">
        <div class="detail-copy">
          <a class="back-link" href={asset("#lineas")}>Volver a líneas de trabajo</a>
          <p class="eyebrow">Línea de trabajo</p>
          <h1>Desarrollo de software + IA</h1>
          <p class="lead">
            Estrategias para pasar de la intuición creativa a la definición formal,
            integrando prompts, agentes y especificaciones en ciclos de desarrollo asistido
          </p>
        </div>
        <figure class="detail-visual">
          <img
            src={asset("lineas/desarrolloIA/desarrolloIAVibe-web.png")}
            alt="Flujo de desarrollo asistido por IA: vibe coding, prompts y especificaciones"
          />
        </figure>
      </section>

      <section class="section detail-content">
        <article class="detail-diagnosis">
          <p class="eyebrow">Diagnóstico previo</p>
          <p>
            La estrategia debe partir de las necesidades de la empresa y del cliente.
            No existe un enfoque único: se equilibra agilidad, criticidad, seguridad
            y trazabilidad según el contexto del sistema
          </p>
        </article>

        <div class="detail-grid">
          {
            strategies.map((item) => (
              <article class="detail-card">
                <span>{item.step}</span>
                <h2>{item.title}</h2>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>

        <article class="detail-formal">
          <div>
            <p class="eyebrow">Definición y formalidad</p>
            <h2>Desarrollo por especificaciones</h2>
            <p>
              Para sistemas empresariales y de misión crítica, el desarrollo se apoya
              en especificaciones detalladas, modelado de datos, diagramas de arquitectura
              y agentes de IA que ayudan a mantener consistencia de extremo a extremo
            </p>
          </div>
          <div class="detail-tags" aria-label="Componentes del enfoque formal">
            {tags.map((tag) => <span>{tag}</span>)}
          </div>
        </article>

        <article class="download-panel">
          <div>
            <p class="eyebrow">Documento técnico</p>
            <h2>Slides de especificación</h2>
            <p>
              Material ampliado sobre el proceso de desarrollo de software con IA,
              incluyendo criterios técnicos y enfoque de especificación
            </p>
          </div>
          <a
            class="download-button"
            href={asset("lineas/desarrolloIA/slides_spec.pdf")}
            download="slides_spec.pdf"
          >
            Descargar PDF
          </a>
        </article>
      </section>
    </main>
  </body>
</html>
